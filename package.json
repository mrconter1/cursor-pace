{
  "name": "cursor-pace",
  "displayName": "Cursor Pace",
  "description": "Track and pace your Cursor AI spending with daily budget limits",
  "version": "0.1.2",
  "publisher": "mrconter1",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrconter1/cursor-pace"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorPace.openDashboard",
        "title": "Cursor Pace: Open Dashboard"
      },
      {
        "command": "cursorPace.refresh",
        "title": "Cursor Pace: Refresh Usage Data"
      },
      {
        "command": "cursorPace.debugWarn",
        "title": "Cursor Pace [Debug]: Trigger Warn Threshold"
      },
      {
        "command": "cursorPace.debugOverBudget",
        "title": "Cursor Pace [Debug]: Trigger Over Budget"
      },
      {
        "command": "cursorPace.debugUntracked",
        "title": "Cursor Pace [Debug]: Trigger Untracked Model Warning"
      }
    ],
    "configuration": {
      "title": "Cursor Pace",
      "properties": {
        "cursorPace.subscription": {
          "type": "string",
          "default": "ultra",
          "enum": [
            "hobby",
            "pro",
            "pro_plus",
            "ultra",
            "teams",
            "custom"
          ],
          "enumDescriptions": [
            "Hobby (Free)",
            "Pro ($20/mo)",
            "Pro+ ($60/mo)",
            "Ultra ($200/mo)",
            "Teams ($40/user/mo)",
            "Custom"
          ],
          "description": "Your Cursor subscription plan"
        },
        "cursorPace.monthlyBudget": {
          "type": "number",
          "default": 200,
          "description": "Monthly budget in USD"
        },
        "cursorPace.warnThreshold": {
          "type": "number",
          "default": 80,
          "description": "Warn when daily spend reaches this % of daily budget"
        },
        "cursorPace.historyDays": {
          "type": "number",
          "default": 90,
          "enum": [
            30,
            90
          ],
          "enumDescriptions": [
            "Last 30 days",
            "Last 3 months"
          ],
          "description": "How far back to fetch usage history for cost calibration"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {}
}
